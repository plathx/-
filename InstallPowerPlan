# 1. ตรวจสอบสิทธิ์ Admin
if (-not ([Security.Principal.WindowsPrincipal][Security.Principal.WindowsIdentity]::GetCurrent()).IsInRole([Security.Principal.WindowsBuiltInRole] "Administrator")) {
    $arguments = "-NoProfile -ExecutionPolicy Bypass -File `"$PSCommandPath`""
    Start-Process powershell -ArgumentList $arguments -Verb RunAs
    exit
}

# 2. สร้าง System Restore Point
Write-Host "--- กำลังสร้าง System Restore Point (กรุณารอ...) ---" -ForegroundColor Cyan
try {
    Checkpoint-Computer -Description "PowerPlanInstall" -RestorePointType "MODIFY_SETTINGS"
    Write-Host "สร้าง Restore Point เรียบร้อย" -ForegroundColor Green
} catch {
    Write-Host "ข้ามการสร้าง Restore Point..." -ForegroundColor Yellow
}

# 3. ใช้โฟลเดอร์ชั่วคราวแบบสุ่ม เพื่อเลี่ยงปัญหาไฟล์ค้างจากการรันครั้งก่อน
$workDir = "$env:TEMP\PowerPlans_" + [Guid]::NewGuid().ToString().Substring(0,8)
New-Item -ItemType Directory -Path $workDir | Out-Null
Set-Location $workDir

# 4. ดาวน์โหลดไฟล์
$files = @{
    "KernelOS.pow" = "https://is.gd/dtF1gW"
    "Ultimate.pow" = "https://is.gd/Fly5ky"
}

foreach ($name in $files.Keys) {
    Write-Host "กำลังดาวน์โหลด $name ..." -ForegroundColor Yellow
    Invoke-WebRequest -Uri $files[$name] -OutFile "$workDir\$name" -UseBasicParsing
}

# 5. ฟังก์ชัน Import
function Import-PowerPlan {
    param([string]$FilePath)
    $output = powercfg -import "$FilePath"
    $match = [regex]::Match($output, '\{[a-f0-9-]{36}\}')
    if ($match.Success) { return $match.Value.Trim('{}') }
    return $null
}

Write-Host "กำลังติดตั้ง Power Plans..." -ForegroundColor Green
$ultGuid = Import-PowerPlan "$workDir\Ultimate.pow"
$kernGuid = Import-PowerPlan "$workDir\KernelOS.pow"

# 6. ตั้งค่า Active
if ($ultGuid) {
    powercfg -setactive $ultGuid
    Write-Host "ติดตั้งและเปิดใช้งาน Ultimate Performance สำเร็จ ($ultGuid)" -ForegroundColor Green
} else {
    Write-Host "เกิดข้อผิดพลาดในการ Import" -ForegroundColor Red
}

Write-Host "`nเสร็จสิ้น! ทุกอย่างเรียบร้อยดีครับ" -ForegroundColor White
Read-Host "กด Enter เพื่อปิดหน้าต่างนี้..."
