# 1. ขอสิทธิ์ Admin
if (-not ([Security.Principal.WindowsPrincipal][Security.Principal.WindowsIdentity]::GetCurrent()).IsInRole([Security.Principal.WindowsBuiltInRole] "Administrator")) {
    Start-Process powershell -ArgumentList "-NoProfile -ExecutionPolicy Bypass -File `"$PSCommandPath`"" -Verb RunAs
    exit
}

# 2. สร้าง Restore Point
Write-Host "--- กำลังสร้าง System Restore Point ---" -ForegroundColor Cyan
Checkpoint-Computer -Description "PowerPlanInstall" -RestorePointType "MODIFY_SETTINGS" -ErrorAction SilentlyContinue

# 3. เตรียมโฟลเดอร์ทำงาน (ใช้ C:\PowerPlans เพื่อเลี่ยงปัญหา Temp)
$workDir = "C:\PowerPlans"
if (!(Test-Path $workDir)) { New-Item -ItemType Directory -Path $workDir | Out-Null }
Set-Location $workDir

# 4. ดาวน์โหลดไฟล์
$files = @{
    "KernelOS.pow" = "https://github.com/halks0/KernelOS-Power-Plan/raw/master/KernelOS%20Performance%20V6.1%20IDLE%20ON.pow"
    "Ultimate.pow" = "https://github.com/halks0/Ultimate-Performance-Power-Plan/raw/master/UltimatePerformance.pow"
}

foreach ($name in $files.Keys) {
    Write-Host "กำลังดาวน์โหลด $name ..." -ForegroundColor Yellow
    Invoke-WebRequest -Uri $files[$name] -OutFile "$workDir\$name" -UseBasicParsing
}

# 5. ติดตั้งและหา GUID ด้วยการ List ดู
Write-Host "กำลังติดตั้งและค้นหา GUID..." -ForegroundColor Green

# ลบแผนเดิมที่อาจมีชื่อซ้ำกันก่อน (เพื่อป้องกันการ Import ล้มเหลว)
powercfg -import "$workDir\Ultimate.pow"
powercfg -import "$workDir\KernelOS.pow"

# ใช้คำสั่ง List เพื่อดึงแผนการใช้พลังงานล่าสุด
$plans = powercfg -list
Write-Host "แผนการใช้พลังงานที่พบ:" -ForegroundColor Gray
$plans | Select-String "Ultimate" -Context 0,1

# พยายามตั้ง Active โดยใช้การหา GUID จากชื่อไฟล์หรือรายการ
# ในที่นี้จะลองใช้คำสั่งตั้ง Active ตรงๆ ด้วยชื่อแผน
$targetPlan = $plans | Select-String "Ultimate"
if ($targetPlan) {
    $guid = ($targetPlan.ToString() -split "\s+")[3]
    powercfg -setactive $guid
    Write-Host "ตั้งค่า Active สำเร็จที่ GUID: $guid" -ForegroundColor Green
} else {
    Write-Host "ไม่พบแผน Ultimate Performance กรุณาเช็คใน Control Panel > Power Options" -ForegroundColor Red
}

Write-Host "`nเสร็จสิ้น! หากไม่พบแผนพลังงาน ให้ลองเข้าไปดูใน Control Panel > Power Options"
Read-Host "กด Enter เพื่อปิด..."
