# 1. ติดตั้ง Python Libraries ที่จำเป็นแบบเงียบๆ
Write-Host "--- Initializing Python Environment ---" -ForegroundColor Cyan
$libraries = "requests", "pyqrcode", "pypng", "pyperclip"
foreach ($lib in $libraries) {
    python -m pip install $lib --quiet
}

# 2. ตัวสคริปต์ Python
$pythonCode = @'
import sys
import requests
import pyqrcode
import pyperclip
import os
import tkinter as tk
from tkinter import filedialog

def select_files():
    root = tk.Tk()
    root.withdraw() # ซ่อนหน้าต่างหลักของ tkinter
    files = filedialog.askopenfilenames(title="เลือกไฟล์ที่ต้องการแชร์")
    return files

def upload_and_share(file_paths):
    # ใช้ oshi.at หรือ transfer.sh สำหรับ API-based sharing
    # ในที่นี้ใช้ oshi.at เพราะรองรับการตั้งเวลาลบไฟล์ได้
    
    upload_urls = []
    print("\n[+] กำลังอัปโหลดไฟล์ไปยัง P2P Proxy...")

    for path in file_paths:
        file_name = os.path.basename(path)
        try:
            with open(path, 'rb') as f:
                # อัปโหลดไฟล์ (ตั้งให้อยู่ได้ 1 ชั่วโมงเพื่อความปลอดภัย)
                response = requests.post('https://oshi.at', files={'f': (file_name, f)}, data={'expire': '60'})
                if response.status_code == 200:
                    # ดึงเอา Download Link จาก response (oshi.at จะคืนค่าเป็น Text)
                    lines = response.text.split('\n')
                    for line in lines:
                        if "DL:" in line:
                            link = line.replace("DL:", "").strip()
                            upload_urls.append(link)
                            break
        except Exception as e:
            print(f"❌ Error uploading {file_name}: {e}")

    if not upload_urls:
        return None

    # ถ้ามีหลายไฟล์ เราจะเอาลิ้งค์แรกมาเป็นตัวแทน หรือรวมลิ้งค์
    main_link = upload_urls[0]
    
    # ย่อลิ้งค์ด้วย is.gd
    try:
        short_url = requests.get(f"https://is.gd/create.php?format=simple&url={main_link}", timeout=5).text
    except:
        short_url = main_link

    # สร้าง QR Code
    qr = pyqrcode.create(short_url)
    
    print("\n" + "█"*50)
    print("      READY TO DOWNLOAD")
    print("█" * 50 + "\n")
    print(qr.terminal(quiet_zone=1))
    print("\n" + "-"*50)
    print(f"🔗 Short Link: {short_url}")
    
    # Copy to Clipboard
    pyperclip.copy(short_url)
    print("✅ คัดลอกลิ้งค์ลง Clipboard เรียบร้อยแล้ว!")
    print("-" * 50)
    print(f"📦 ไฟล์ทั้งหมด: {len(file_paths)} ไฟล์")

if __name__ == "__main__":
    selected = select_files()
    if selected:
        upload_and_share(selected)
    else:
        print("❌ ไม่ได้เลือกไฟล์")
'@

# บันทึกและรัน
$tempFile = "$env:TEMP\p2p_active.py"
$pythonCode | Out-File -FilePath $tempFile -Encoding utf8
python $tempFile
Remove-Item $tempFile
