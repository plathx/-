# 1. ตรวจสอบสิทธิ์ Administrator
if (-not ([Security.Principal.WindowsPrincipal][Security.Principal.WindowsIdentity]::GetCurrent()).IsInRole([Security.Principal.WindowsBuiltInRole]::Administrator)) {
    Write-Host "Requesting Administrative privileges..." -ForegroundColor Yellow
    Start-Process powershell.exe -ArgumentList "-NoProfile -ExecutionPolicy Bypass -File `"$PSCommandPath`"" -Verb RunAs
    exit
}

# กำหนดเส้นทาง
$scriptPath = "C:\scripts"
$psFile = Join-Path $scriptPath "share_file.ps1"

# 2. สร้างโฟลเดอร์สำหรับเก็บสคริปต์
if (-not (Test-Path $scriptPath)) {
    New-Item -Path $scriptPath -ItemType Directory | Out-Null
    Write-Host "[1/3] Folder $scriptPath created." -ForegroundColor Green
} else {
    Write-Host "[1/3] Folder $scriptPath already exists." -ForegroundColor Cyan
}

# 3. สร้างไฟล์สคริปต์สำหรับการอัปโหลด (share_file.ps1)
Write-Host "[2/3] Creating upload script..." -ForegroundColor Yellow
$uploadScriptContent = @'
param($filePath)

if (-not $filePath -or -not (Test-Path $filePath)) { exit }

$fileName = [System.IO.Path]::GetFileName($filePath)

try {
    Write-Host "Connecting to Gofile..." -ForegroundColor Cyan
    # รับข้อมูล Server ที่ว่างอยู่
    $serverInfo = Invoke-RestMethod -Uri "https://api.gofile.io/servers"
    if ($serverInfo.status -ne "ok") { throw "Cannot get server info" }
    
    $server = $serverInfo.data.servers[0].name
    Write-Host "Uploading: $fileName" -ForegroundColor Yellow
    Write-Host "Server: $server" -ForegroundColor DarkGray
    Write-Host ("-" * 50)

    # ใช้ curl.exe (มีติดมากับ Windows) ในการส่งไฟล์แบบ Multipart
    $tempResult = [System.IO.Path]::GetTempFileName()
    curl.exe -# -F "file=@$filePath" "https://$server.gofile.io/contents/uploadfile" -o $tempResult
    
    $response = Get-Content $tempResult -Raw | ConvertFrom-Json
    Remove-Item $tempResult

    if ($response.status -eq "ok") {
        $link = $response.data.downloadPage
        # Copy ลิงก์ลง Clipboard
        Set-Clipboard -Value $link
        
        Write-Host ("-" * 50)
        Write-Host "UPLOAD COMPLETE!" -ForegroundColor Green
        Write-Host "Link: $link" -ForegroundColor Cyan
        Write-Host "Link has been copied to your clipboard."
        
        # แสดง MessageBox แจ้งเตือน
        Add-Type -AssemblyName System.Windows.Forms
        [System.Windows.Forms.MessageBox]::Show("Upload Finished!`n`nLink: $link", "Success")
    } else {
        Write-Host "Upload failed: $($response.status)" -ForegroundColor Red
        Pause
    }
}
catch {
    Write-Host "Error: $_" -ForegroundColor Red
    Pause
}
'@

Set-Content -Path $psFile -Value $uploadScriptContent -Encoding UTF8

# 4. ตั้งค่า Context Menu ใน Registry
Write-Host "[3/3] Setting up Context Menu (Registry)..." -ForegroundColor Yellow

$registryPath = "Registry::HKEY_CLASSES_ROOT\*\shell\CreateLink"
$commandPath = "$registryPath\command"

if (-not (Test-Path $registryPath)) {
    New-Item -Path $registryPath -Force | Out-Null
}

Set-ItemProperty -Path $registryPath -Name "(Default)" -Value "Get Gofile Link"
Set-ItemProperty -Path $registryPath -Name "Icon" -Value "imageres.dll,-1024"

if (-not (Test-Path $commandPath)) {
    New-Item -Path $commandPath -Force | Out-Null
}

# สั่งให้รัน PowerShell แบบซ่อนหน้าต่างหลักหรือเปิดขึ้นมาทำงาน
$commandValue = "powershell.exe -ExecutionPolicy Bypass -File `"$psFile`" `"%1`""
Set-ItemProperty -Path $commandPath -Name "(Default)" -Value $commandValue

Write-Host ("-" * 50) -ForegroundColor Gray
Write-Host "DONE! Setup completed successfully." -ForegroundColor Green
Write-Host "You can now right-click any file and select 'Get Gofile Link'." -ForegroundColor White
Write-Host ("-" * 50) -ForegroundColor Gray
Pause
