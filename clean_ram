# เคลียร์หน่วยความจำก่อนเริ่ม
Remove-Variable * -ErrorAction SilentlyContinue

# ฟังก์ชันดาวน์โหลดและแตกไฟล์
function Get-CleanRAM {
    $targetDir = "C:\phwyverysad"
    $zipPath = "$targetDir\CleanRAM.zip"
    
    if (-not (Test-Path $targetDir)) { New-Item -Path $targetDir -ItemType Directory | Out-Null }
    
    Write-Host "กำลังดาวน์โหลดไฟล์..." -ForegroundColor Cyan
    $client = New-Object System.Net.WebClient
    $client.DownloadFile("https://is.gd/pURUxe", $zipPath)
    
    Write-Host "กำลังแตกไฟล์ด้วยคำสั่งมาตรฐาน..." -ForegroundColor Cyan
    # ใช้ Expand-Archive เท่านั้น ไม่มีการเรียก [System.IO.Compression.ZipFile] อีกต่อไป
    Expand-Archive -Path $zipPath -DestinationPath $targetDir -Force
    
    # ย้าย EmptyStandbyList.exe ไปยัง System32
    if (Test-Path "$targetDir\EmptyStandbyList.exe") {
        Move-Item -Path "$targetDir\EmptyStandbyList.exe" -Destination "C:\Windows\System32\EmptyStandbyList.exe" -Force
        Write-Host "ย้ายไฟล์ไปยัง System32 สำเร็จ" -ForegroundColor Green
    }
}

# ฟังก์ชันล้างโฟลเดอร์ชั่วคราว
function Cleanup {
    $targetDir = "C:\phwyverysad"
    if (Test-Path $targetDir) {
        Remove-Item -Path $targetDir -Recurse -Force
        Write-Host "ล้างไฟล์ชั่วคราวเรียบร้อยแล้ว" -ForegroundColor Gray
    }
}

# เมนู
Write-Host "--- เมนูจัดการ RAM ---"
Write-Host "1. สร้างทางลัด"
Write-Host "2. ตั้งเวลาเคลียร์อัตโนมัติ"
Write-Host "3. ยกเลิกการตั้งเวลาอัตโนมัติ"
$choice = Read-Host "เลือกเมนู (1-3)"

switch ($choice) {
    "1" {
        Get-CleanRAM
        $desktopPath = [System.IO.Path]::Combine($env:USERPROFILE, "Desktop")
        $oneDriveDesktop = [System.IO.Path]::Combine($env:USERPROFILE, "OneDrive\Desktop")
        
        $shortcut = Get-ChildItem -Path "C:\phwyverysad" -Filter "*.lnk" | Select-Object -First 1
        if ($shortcut) {
            Copy-Item -Path $shortcut.FullName -Destination $desktopPath -Force
            if (Test-Path $oneDriveDesktop) { Copy-Item -Path $shortcut.FullName -Destination $oneDriveDesktop -Force }
            Write-Host "สร้างทางลัดบน Desktop สำเร็จ" -ForegroundColor Green
        }
        Cleanup
    }
    
    "2" {
        $minutes = Read-Host "ใส่จำนวนเวลา (นาที)"
        Get-CleanRAM
        $taskCommand = "cmd.exe /c EmptyStandbyList.exe workingsets && EmptyStandbyList.exe standbylist && EmptyStandbyList.exe modifiedpagelist"
        schtasks /create /tn "AutoCleanRAM" /sc MINUTE /mo $minutes /rl HIGHEST /ru SYSTEM /tr $taskCommand /f
        Write-Host "ตั้งค่า AutoCleanRAM ทุกๆ $minutes นาที เรียบร้อย" -ForegroundColor Green
        Cleanup
    }
    
    "3" {
        schtasks /delete /tn "AutoCleanRAM" /f
        Write-Host "ยกเลิกการตั้งเวลาอัตโนมัติเรียบร้อยแล้ว" -ForegroundColor Yellow
    }
}
