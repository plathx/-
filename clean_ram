# สคริปต์จัดการ CleanRAM (EmptyStandbyList)
# 1. สร้างทางลัด | 2. ตั้งเวลาอัตโนมัติ | 3. ยกเลิกการตั้งเวลา

# ตรวจสอบสิทธิ์ Administrator (จำเป็นสำหรับการเขียนไฟล์ลง System32 และสร้าง Task)
if (-not ([Security.Principal.WindowsPrincipal][Security.Principal.WindowsIdentity]::GetCurrent()).IsInRole([Security.Principal.WindowsBuiltInRole]::Administrator)) {
    Write-Host "กำลังขอสิทธิ์ Administrator..." -ForegroundColor Yellow
    Start-Process powershell.exe "-NoProfile -ExecutionPolicy Bypass -File `"$PSCommandPath`"" -Verb RunAs
    exit
}

# บังคับใช้ TLS 1.2 สำหรับการดาวน์โหลดที่ปลอดภัย
[Net.ServicePointManager]::SecurityProtocol = [Net.SecurityProtocolType]::Tls12

Clear-Host
Write-Host "=== CleanRAM Management System ===" -ForegroundColor Cyan
Write-Host "1. สร้างทางลัด (Shortcut)"
Write-Host "2. ตั้งเวลาเคลียร์อัตโนมัติ (Schedule Task)"
Write-Host "3. ยกเลิกการตั้งเวลาอัตโนมัติ (Remove Task)"
$choice = Read-Host "กรุณาเลือกตัวเลือก (1-3)"

$tempFolder = "C:\phwyverysad"
$downloadUrl = "https://is.gd/pURUxe"
$zipPath = "$tempFolder\CleanRAM.zip"

# ฟังก์ชันจัดการการดาวน์โหลดและเตรียมไฟล์
function Setup-Files {
    if (Test-Path $tempFolder) { Remove-Item $tempFolder -Recurse -Force -ErrorAction SilentlyContinue }
    New-Item -ItemType Directory -Path $tempFolder | Out-Null
    
    Write-Host "กำลังดาวน์โหลดไฟล์..." -ForegroundColor Green
    
    # ใช้ WebClient พร้อมการตั้งค่า Header ที่เลียนแบบ Browser มากขึ้น
    $webClient = New-Object System.Net.WebClient
    $webClient.Headers.Add("User-Agent", "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36")
    $webClient.Headers.Add("Accept", "*/*")
    
    try {
        $webClient.DownloadFile($downloadUrl, $zipPath)
        
        # ตรวจสอบเบื้องต้นว่าไฟล์ที่ได้มาคือ Zip หรือไม่ (ตรวจสอบ Header PK)
        $bytes = Get-Content $zipPath -Encoding Byte -TotalCount 2
        if ($bytes[0] -ne 0x50 -or $bytes[1] -ne 0x4B) {
            throw "ไฟล์ที่ดาวน์โหลดไม่ใช่ไฟล์ Zip ที่ถูกต้อง (อาจโดนบล็อกหรือลิงก์เปลี่ยน)"
        }
    } catch {
        Write-Host "เกิดข้อผิดพลาดในการดาวน์โหลด: $_" -ForegroundColor Red
        return $false
    }

    Write-Host "กำลังแตกไฟล์..." -ForegroundColor Green
    try {
        $extractPath = "$tempFolder\Extracted"
        # แตกไฟล์โดยตรง
        Expand-Archive -Path $zipPath -DestinationPath $extractPath -Force

        # ค้นหาไฟล์ที่จำเป็น
        $exeFile = Get-ChildItem -Path $extractPath -Filter "EmptyStandbyList.exe" -Recurse | Select-Object -First 1
        $lnkFile = Get-ChildItem -Path $extractPath -Filter "CleanRAM.lnk" -Recurse | Select-Object -First 1

        if ($exeFile) {
            Write-Host "กำลังติดตั้ง EmptyStandbyList ไปยัง System32..." -ForegroundColor Gray
            Move-Item -Path $exeFile.FullName -Destination "C:\Windows\System32\" -Force
            
            if ($lnkFile) { 
                Copy-Item -Path $lnkFile.FullName -Destination "$tempFolder\CleanRAM.lnk" -Force 
            }
            return $true
        } else {
            Write-Host "ไม่พบไฟล์ EmptyStandbyList.exe ในแพ็กเกจ" -ForegroundColor Red
            return $false
        }
    } catch {
        Write-Host "เกิดข้อผิดพลาดในการแตกไฟล์: $_" -ForegroundColor Red
        Write-Host "คำแนะนำ: หากยังพบข้อผิดพลาดเดิม อาจเป็นเพราะไฟล์ถูกดาวน์โหลดมาไม่สมบูรณ์เนื่องจากความเร็วเน็ตหรือ Server" -ForegroundColor Yellow
        return $false
    }
}

# ฟังก์ชันลบไฟล์ขยะ
function Clean-Up {
    if (Test-Path $tempFolder) {
        Remove-Item -Path $tempFolder -Recurse -Force -ErrorAction SilentlyContinue
        Write-Host "ลบไฟล์ชั่วคราวเรียบร้อยแล้ว" -ForegroundColor Gray
    }
}

switch ($choice) {
    "1" {
        if (Setup-Files) {
            $desktopPaths = @(
                "$env:USERPROFILE\Desktop\CleanRAM.lnk",
                "$env:USERPROFILE\OneDrive\Desktop\CleanRAM.lnk"
            )

            foreach ($path in $desktopPaths) {
                $dir = Split-Path $path
                if (Test-Path $dir) {
                    if (Test-Path "$tempFolder\CleanRAM.lnk") {
                        Copy-Item -Path "$tempFolder\CleanRAM.lnk" -Destination $path -Force
                        Write-Host "สร้างทางลัดที่: $path" -ForegroundColor Cyan
                    }
                }
            }
        }
        Clean-Up
    }
    
    "2" {
        $minutes = Read-Host "ระบุจำนวนเวลาที่ต้องการ (นาที)"
        if ($minutes -as [int]) {
            if (Setup-Files) {
                Write-Host "กำลังตั้งเวลาทำงานทุกๆ $minutes นาที..." -ForegroundColor Yellow
                $command = 'cmd.exe /c "EmptyStandbyList.exe workingsets && EmptyStandbyList.exe standbylist && EmptyStandbyList.exe modifiedpagelist"'
                
                schtasks /create /tn "AutoCleanRAM" /sc MINUTE /mo $minutes /rl HIGHEST /ru SYSTEM /tr $command /f
                Write-Host "ตั้งเวลาเรียบร้อยแล้ว!" -ForegroundColor Green
            }
            Clean-Up
        } else {
            Write-Host "กรุณาใส่ตัวเลขที่ถูกต้อง" -ForegroundColor Red
        }
    }

    "3" {
        Write-Host "กำลังยกเลิกการตั้งเวลาอัตโนมัติ..." -ForegroundColor Yellow
        schtasks /delete /tn "AutoCleanRAM" /f
        Write-Host "ยกเลิกเรียบร้อยแล้ว" -ForegroundColor Green
    }

    Default {
        Write-Host "ตัวเลือกไม่ถูกต้อง" -ForegroundColor Red
    }
}

Write-Host "`nเสร็จสิ้นกระบวนการ กดปุ่มใดก็ได้เพื่อออก..."
$null = $Host.UI.RawUI.ReadKey("NoEcho,IncludeKeyDown")# สคริปต์จัดการ CleanRAM (EmptyStandbyList)
